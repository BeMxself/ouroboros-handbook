# 潮汐栈版本号
OUROBOROS_VERSION=1.0.0-beta.2

# 开发平台访问端口
PLATFORM_PORT=80

# 远程调试端口，不需要时可删除 compose 中对应映射
DEBUG_PORT=15005

# MySQL 暴露到宿主机的端口
MYSQL_PORT=13306

# 必填：宿主机 workspace 绝对路径
HOST_WORKSPACE_PATH=/absolute/path/to/tidestack-develop/workspace

# 建议首次部署前修改
MYSQL_ROOT_PASSWORD=ChangeMe123!

# RabbitMQ 配置（默认用户名和密码）
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Apple Silicon 芯片如需 ARM64 镜像可取消注释
# ARCH_AFFIX=-arm64
